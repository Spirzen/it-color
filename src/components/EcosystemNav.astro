---
import ThemeToggle from './ThemeToggle.astro';

/** @typedef {{ id: string, label: string, href: string, active?: boolean }} NavItem */

interface Props {
  brandLabel: string;
  brandHref: string;
  navItems: NavItem[];
}

const {brandLabel, brandHref, navItems} = Astro.props;
---

<header class="ecosystem-nav">
  <a class="ecosystem-nav__brand" href={brandHref}>
    <span class="ecosystem-nav__brand-mark" aria-hidden="true">◐</span>
    <span>{brandLabel}</span>
  </a>
  <nav class="ecosystem-nav__links" aria-label="Экосистема Вселенная IT">
    {
      navItems.map((item) => (
        <a
          class:list={['ecosystem-nav__link', item.active && 'is-active']}
          href={item.href}
          aria-current={item.active ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="ecosystem-nav__actions">
    <ThemeToggle />
  </div>
</header>

<style>
  .ecosystem-nav__brand-mark {
    background: conic-gradient(from 180deg, #f43f5e, #eab308, #22c55e, #3b82f6, #a855f7, #f43f5e);
    color: transparent;
    font-size: 1rem;
  }
</style>
